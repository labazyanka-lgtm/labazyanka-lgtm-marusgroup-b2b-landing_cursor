# --- Заявки с формы (минимум для staging/production) ---
# Нужен хотя бы один канал: Resend ИЛИ webhook. Иначе POST /api/estimate вернёт 503.
#
# Вариант A — только webhook (например staging без почты):
#   ESTIMATE_WEBHOOK_URL=https://your-hook.example/estimate
#
# Вариант B — почта через Resend (https://resend.com):
RESEND_API_KEY=
ESTIMATE_EMAIL_FROM=
ESTIMATE_EMAIL_TO=info@marusgroup.ru
#
# Вариант C — и почта, и дублирование в CRM:
ESTIMATE_WEBHOOK_URL=

# --- Публичный блок контактов и реквизитов (опционально) ---
# Пусто — на сайте остаются заглушки «уточняется» / текст по умолчанию для адреса.
NEXT_PUBLIC_LEGAL_ENTITY_NAME=
NEXT_PUBLIC_COMPANY_INN=
NEXT_PUBLIC_COMPANY_OGRN=
NEXT_PUBLIC_COMPANY_KPP=
NEXT_PUBLIC_OFFICE_ADDRESS=
NEXT_PUBLIC_OFFICE_HOURS=

# --- Аналитика (пусто — скрипты не грузятся) ---
NEXT_PUBLIC_YANDEX_METRIKA_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
