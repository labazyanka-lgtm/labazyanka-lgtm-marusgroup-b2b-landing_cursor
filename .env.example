# ──────────────────────────────────────────────────────────────────────────────
# Site
# ──────────────────────────────────────────────────────────────────────────────
# Базовый URL продакшена. Используется в Open Graph / metadataBase.
NEXT_PUBLIC_SITE_URL=https://marusgroup.ru

# ──────────────────────────────────────────────────────────────────────────────
# Analytics  (любая комбинация — необязательно подключать обе)
# ──────────────────────────────────────────────────────────────────────────────
# TODO[real-data]: ID счётчика Яндекс.Метрики.
NEXT_PUBLIC_YANDEX_METRIKA_ID=
# TODO[real-data]: GA4 Measurement ID (формат G-XXXXXXX).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ──────────────────────────────────────────────────────────────────────────────
# Доставка заявок с формы /api/estimate
# Можно подключить любую комбинацию каналов — каждый работает независимо.
# Если ничего не настроено, заявка пишется в server-лог.
# ──────────────────────────────────────────────────────────────────────────────

# Telegram-бот
ESTIMATE_TELEGRAM_BOT_TOKEN=
ESTIMATE_TELEGRAM_CHAT_ID=

# Универсальный JSON-webhook (Make / n8n / собственный CRM)
ESTIMATE_WEBHOOK_URL=

# Email через Resend
RESEND_API_KEY=
ESTIMATE_NOTIFY_EMAIL=
ESTIMATE_NOTIFY_FROM=
