################################################################################
# MARUS GROUP — переменные окружения
#
# Скопируйте в `.env.local` (для локалки) или задайте на хостинге деплоя.
# Все значения, помеченные `PLACEHOLDER`, обязательно заменить перед боевым
# запуском (см. также `lib/site-config.ts`).
################################################################################

# ─── Сайт ─────────────────────────────────────────────────────────────────────
# Базовый URL продакшн-сайта. Используется в metadata, sitemap и robots.
NEXT_PUBLIC_SITE_URL=https://marusgroup.ru

# ─── Аналитика ────────────────────────────────────────────────────────────────
# ID счётчика Яндекс.Метрики (число).
# TODO[real-data]: создать счётчик и подставить ID.
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Measurement ID Google Analytics 4 (формат `G-XXXXXXX`).
# TODO[real-data]: создать поток GA4 и подставить ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Доставка заявок из формы (минимум один канал) ────────────────────────────
# Канал 1: Telegram-бот (см. https://core.telegram.org/bots#how-do-i-create-a-bot).
# TODO[real-data]: создать бота через @BotFather, получить токен и chat_id.
ESTIMATE_TELEGRAM_BOT_TOKEN=
ESTIMATE_TELEGRAM_CHAT_ID=

# Канал 2: универсальный JSON-webhook (Make / n8n / собственный CRM-приёмник).
# Принимает POST application/json со всеми полями заявки.
ESTIMATE_WEBHOOK_URL=

# Канал 3: email через сервис Resend (https://resend.com/), без SMTP-зависимостей.
# TODO[real-data]: завести аккаунт Resend и получить ключ.
RESEND_API_KEY=
ESTIMATE_NOTIFY_EMAIL=
# Опционально: адрес отправителя; по умолчанию — `MARUS GROUP <onboarding@resend.dev>`.
ESTIMATE_NOTIFY_FROM=
